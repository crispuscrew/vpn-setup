# Managed by Ansible (vpn-setup). Do not edit by hand.
SQLALCHEMY_DATABASE_URL=sqlite:////var/lib/marzneshin/db.sqlite3
# Bind loopback-only when a domain fronts the panel: Caddy, the bot, and register.yml
# all reach it over 127.0.0.1, so nothing needs the public bind and the firewall is no
# longer the only thing closing the port. Bind all interfaces only in IP-only test mode.
UVICORN_HOST={{ '127.0.0.1' if (panel_domain | default('') | length > 0) else '0.0.0.0' }}
UVICORN_PORT={{ panel_port }}
DASHBOARD_PATH=/dashboard/
DOCS={{ (panel_docs | default(true)) | string | lower }}
SUBSCRIPTION_URL_PREFIX={{ subscription_url_prefix | trim }}
SUDO_USERNAME={{ panel_sudo_username }}
SUDO_PASSWORD={{ panel_sudo_password }}
