# Managed by Ansible (vpn-setup). All-in-one node: loopback + INSECURE, matching
# the panel's auto-created "local" grpcio node (plaintext over 127.0.0.1 only —
# never on the wire). Remote nodes (Phase 4) switch to grpclib + client cert.
SERVICE_ADDRESS=127.0.0.1
SERVICE_PORT={{ marznode_port }}
INSECURE=True
XRAY_ENABLED=True
XRAY_EXECUTABLE_PATH=/usr/local/bin/xray
XRAY_ASSETS_PATH=/usr/local/lib/xray
XRAY_CONFIG_PATH=/var/lib/marznode/xray_config.json
