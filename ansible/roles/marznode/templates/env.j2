# Managed by Ansible (vpn-setup).
{% if node_mode == 'remote' %}
# Remote node: listens on all interfaces and authenticates the panel over mutual
# TLS using the panel's client certificate (fetched from /api/nodes/settings).
# marznode auto-generates its own server keypair on first start.
SERVICE_ADDRESS=0.0.0.0
SERVICE_PORT={{ marznode_port }}
INSECURE=False
SSL_CERT_FILE={{ marznode_dir }}/ssl_cert.pem
SSL_KEY_FILE={{ marznode_dir }}/ssl_key.pem
SSL_CLIENT_CERT_FILE={{ marznode_dir }}/client.pem
{% else %}
# All-in-one node: loopback + INSECURE, matching the panel's auto-created "local"
# grpcio node (plaintext over 127.0.0.1 only, never on the wire).
SERVICE_ADDRESS=127.0.0.1
SERVICE_PORT={{ marznode_port }}
INSECURE=True
{% endif %}
XRAY_ENABLED=True
XRAY_EXECUTABLE_PATH=/usr/local/bin/xray
XRAY_ASSETS_PATH=/usr/local/lib/xray
XRAY_CONFIG_PATH={{ marznode_dir }}/xray_config.json
{% if hysteria2_enabled | default(false) | bool %}
HYSTERIA_ENABLED=True
HYSTERIA_EXECUTABLE_PATH=/usr/local/bin/hysteria
HYSTERIA_CONFIG_PATH={{ marznode_dir }}/hysteria2.yaml
{% endif %}
{% if tuic_enabled | default(false) | bool %}
SING_BOX_ENABLED=True
SING_BOX_EXECUTABLE_PATH=/usr/local/bin/sing-box
SING_BOX_CONFIG_PATH={{ marznode_dir }}/singbox_config.json
{% endif %}
