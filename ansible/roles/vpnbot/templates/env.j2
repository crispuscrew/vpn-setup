# Managed by Ansible (vpn-setup). vpnbot runtime config. Read by docker compose and
# injected into the container; secrets never leave the host.
VPNBOT_TOKEN={{ vpnbot_token }}
VPNBOT_ADMINS={{ vpnbot_admins }}

# The panel runs on this same host; reach it over the loopback (network_mode host),
# so the public port stays closed and there is no TLS hop.
VPN_PANEL_URL=http://127.0.0.1:{{ panel_port }}
VPN_PANEL_USERNAME={{ panel_sudo_username }}
VPN_PANEL_PASSWORD={{ panel_sudo_password }}

VPNBOT_LEDGER=/state/ledger.json

# AmneziaWG delivery: location -> public host, one per awg_enabled node. The bot
# SSHes there with the restricted key below.
{% set _awg = [] %}
{%- for h in groups['all'] | sort %}
{%- if hostvars[h].awg_enabled | default(false) | bool %}
{%- set _ = _awg.append(hostvars[h].location ~ '=' ~ hostvars[h].ansible_host) %}
{%- endif %}
{%- endfor %}
VPNBOT_AWG_NODES={{ _awg | join(',') }}

VPNBOT_SSH_USER=root
VPNBOT_SSH_KEY=/awg_ssh_key
VPNBOT_AWG_SCRIPT={{ vpnbot_awg_script }}
