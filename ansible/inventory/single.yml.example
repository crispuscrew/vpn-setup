# Single throwaway VPS running the whole stack all-in-one (panel + one marznode).
# Copy to inventory/<name>.yml and fill in your values. Real inventory files are
# gitignored; only this .example is tracked.
#
#   cp inventory/single.yml.example inventory/test.yml
#   ansible-playbook site.yml -i inventory/test.yml
all:
  hosts:
    vps:
      ansible_host: "203.0.113.10"          # your VPS IP
  vars:
    ansible_user: root
    ansible_ssh_private_key_file: "~/.ssh/vpn-setup"
    ansible_ssh_common_args: "-o StrictHostKeyChecking=accept-new"

    # ── Panel ────────────────────────────────────────────────────────────────
    # Subscription links are built from this. With a domain use the FQDN + TLS;
    # with no domain (IP-only test mode) leave panel_domain empty and links use
    # http://<ip>:<panel_port>.
    panel_domain: ""                         # e.g. "vpn.example.com"; empty = IP-only
    panel_port: 8000

    # ── Protocols to expose on the node ───────────────────────────────────────
    # Rendered into marznode's core config files (the inbound definitions). Reality
    # needs no owned domain (it borrows reality_sni); Hysteria2/TUIC use TLS (a real
    # cert with a domain, or a self-signed cert in IP-only test mode).
    protocols:
      - vless-reality
      - hysteria2
      - trojan
      - vmess
      - shadowsocks
      # - tuic
      # - shadowtls

    # SNI that VLESS-Reality impersonates when there is no owned domain. Pick a real,
    # reachable TLS 1.3 + X25519 site that is not blocked in the target region.
    # Verified-working: dl.google.com, www.google.com, www.cloudflare.com.
    # AVOID www.microsoft.com — its edge negotiates a handshake xray cannot borrow.
    reality_sni: "dl.google.com"

    # Pinned images come from ../versions.yml — do not hardcode tags here.
